APP_NAME="Rous Cheat API"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rous_cheat_db
DB_USERNAME=root
DB_PASSWORD=

# SQLite (used when DB_DRIVER=sqlite)
SQLITE_PATH=./database/rous_cheat_db.sqlite

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=86400

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Upload
UPLOAD_DIR=./storage/uploads
MAX_FILE_SIZE=5242880
